{
  "info": {
    "name": "E-Commerce Backend API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_postman_id": "ecommerce-backend-api"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "userId",
      "value": "65a1b2c3d4e5f6a7b8c9d0e1",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Categories",
      "item": [
        {
          "name": "Create Category",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/categories", "host": ["{{baseUrl}}"], "path": ["api", "categories"] },
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Electronics\",\n  \"description\": \"Laptops and gadgets\"\n}" }
          }
        },
        {
          "name": "Get All Categories",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/categories", "host": ["{{baseUrl}}"], "path": ["api", "categories"] }
          }
        },
        {
          "name": "Get Single Category",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/categories/:id", "host": ["{{baseUrl}}"], "path": ["api", "categories", ":id"] }
          }
        },
        {
          "name": "Update Category",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/categories/:id", "host": ["{{baseUrl}}"], "path": ["api", "categories", ":id"] },
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Updated Name\"\n}" }
          }
        },
        {
          "name": "Delete Category",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{baseUrl}}/api/categories/:id", "host": ["{{baseUrl}}"], "path": ["api", "categories", ":id"] }
          }
        }
      ]
    },
    {
      "name": "Products",
      "item": [
        {
          "name": "Create Product",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/products", "host": ["{{baseUrl}}"], "path": ["api", "products"] },
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"MacBook Pro 16\",\n  \"price\": 45000,\n  \"stock\": 10,\n  \"category\": \"{{categoryId}}\",\n  \"description\": \"Apple laptop\"\n}" }
          }
        },
        {
          "name": "Get All Products (with filters)",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/products?minPrice=1000&maxPrice=50000&sort=-price&page=1&limit=10", "host": ["{{baseUrl}}"], "path": ["api", "products"] }
          }
        },
        {
          "name": "Get Single Product (populated)",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/products/:id", "host": ["{{baseUrl}}"], "path": ["api", "products", ":id"] }
          }
        },
        {
          "name": "Update Product",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/products/:id", "host": ["{{baseUrl}}"], "path": ["api", "products", ":id"] },
            "body": { "mode": "raw", "raw": "{\n  \"price\": 42000,\n  \"stock\": 5\n}" }
          }
        },
        {
          "name": "Delete Product",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{baseUrl}}/api/products/:id", "host": ["{{baseUrl}}"], "path": ["api", "products", ":id"] }
          }
        }
      ]
    },
    {
      "name": "Cart",
      "item": [
        {
          "name": "Get Cart",
          "request": {
            "method": "GET",
            "header": [{ "key": "x-user-id", "value": "{{userId}}" }],
            "url": { "raw": "{{baseUrl}}/api/cart", "host": ["{{baseUrl}}"], "path": ["api", "cart"] }
          }
        },
        {
          "name": "Add to Cart",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-user-id", "value": "{{userId}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/cart", "host": ["{{baseUrl}}"], "path": ["api", "cart"] },
            "body": { "mode": "raw", "raw": "{\n  \"productId\": \"{{productId}}\",\n  \"quantity\": 2\n}" }
          }
        },
        {
          "name": "Update Cart Item Quantity",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-user-id", "value": "{{userId}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/cart/:productId", "host": ["{{baseUrl}}"], "path": ["api", "cart", ":productId"] },
            "body": { "mode": "raw", "raw": "{\n  \"quantity\": 3\n}" }
          }
        },
        {
          "name": "Remove Item from Cart",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "x-user-id", "value": "{{userId}}" }],
            "url": { "raw": "{{baseUrl}}/api/cart/:productId", "host": ["{{baseUrl}}"], "path": ["api", "cart", ":productId"] }
          }
        },
        {
          "name": "Clear Cart",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "x-user-id", "value": "{{userId}}" }],
            "url": { "raw": "{{baseUrl}}/api/cart", "host": ["{{baseUrl}}"], "path": ["api", "cart"] }
          }
        }
      ]
    },
    {
      "name": "Orders",
      "item": [
        {
          "name": "Checkout (Create Order)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-user-id", "value": "{{userId}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/orders", "host": ["{{baseUrl}}"], "path": ["api", "orders"] }
          }
        },
        {
          "name": "Get My Orders",
          "request": {
            "method": "GET",
            "header": [{ "key": "x-user-id", "value": "{{userId}}" }],
            "url": { "raw": "{{baseUrl}}/api/orders", "host": ["{{baseUrl}}"], "path": ["api", "orders"] }
          }
        },
        {
          "name": "Get Single Order",
          "request": {
            "method": "GET",
            "header": [{ "key": "x-user-id", "value": "{{userId}}" }],
            "url": { "raw": "{{baseUrl}}/api/orders/:id", "host": ["{{baseUrl}}"], "path": ["api", "orders", ":id"] }
          }
        },
        {
          "name": "Update Order Status",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/orders/:id/status", "host": ["{{baseUrl}}"], "path": ["api", "orders", ":id", "status"] },
            "body": { "mode": "raw", "raw": "{\n  \"status\": \"paid\"\n}" }
          }
        }
      ]
    }
  ]
}
